# Copy this file to .env and fill in your values

SECRET_KEY=change-this-to-a-random-secret-key
FLASK_ENV=development

DB_USER=root
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=devbites_db

# Optional: full override (takes precedence over DB_* vars above)
