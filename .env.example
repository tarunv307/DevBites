# Copy this file to .env and fill in your values

SECRET_KEY=change-this-to-a-random-secret-key
FLASK_ENV=development

DB_USER=root
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=devbites_db

# Optional: full override (takes precedence over DB_* vars above)
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/devbites_db# Optional Supabase Postgres connection string:
# SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# Optional Supabase client values (for frontend auth/storage use only):
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=sb_publishable_XXXX